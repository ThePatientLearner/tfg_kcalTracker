<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/txtStatusProtocol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ayuno 16:8"
        android:textColor="#0F172A"
        android:textSize="20sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="20dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/barStatusProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:progress="0"
            app:indicatorColor="#0284C7"
            app:indicatorSize="170dp"
            app:trackColor="#E2E8F0"
            app:trackThickness="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtStatusPhase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AYUNO"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtStatusRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4h 20m"
                android:textColor="#0F172A"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtStatusHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="hasta poder comer"
                android:textColor="#64748B"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/txtStatusDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textAlignment="center"
        android:textColor="#64748B"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStatusChange"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="Cambiar"
            android:textAllCaps="false"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStatusStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#EF4444"
            android:text="Parar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
